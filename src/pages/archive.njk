---
layout: base.njk
title: "Archive"
permalink: /archive/
---
<div class="entries-label">&gt; FULL ARCHIVE <span class="count">// {{ collections.post | length }} entries</span></div>

{% set currentYear = "" %}
{% for post in collections.post | reverse %}

  {% set postYear = post.date | date("yyyy") %}
  {% if postYear != currentYear %}
    {% set currentYear = postYear %}
    <div class="archive-year">{{ currentYear }}</div>
  {% endif %}

  <div class="entries">
    <div class="entry">
      <span class="entry-date">{{ post.date | date("MM.dd") }}</span>
      <span class="entry-tag">{{ post.data.tags[1] | upper }}</span>
      <a href="{{ post.url }}" class="entry-title">{{ post.data.title }}</a>
    </div>
  </div>

{% endfor %}

<div class="cursor-line">_ <span class="blink">▌</span></div>